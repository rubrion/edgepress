---
import { env } from 'cloudflare:workers';
import '../styles/global.css';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	ogType?: 'website' | 'article';
	publishedAt?: Date | null;
}

const clientName = (env.CLIENT_NAME as string | undefined) ?? 'EdgePress';
const themePrimary = (env.THEME_PRIMARY_COLOR as string | undefined) ?? '#2337ff';
const customFavicon = (env.CLIENT_FAVICON_URL as string | undefined) || null;

const { title, description, ogType = 'website', publishedAt } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleJsonLd =
	ogType === 'article'
		? {
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: title,
				description,
				datePublished: publishedAt ? publishedAt.toISOString() : undefined,
				author: { '@type': 'Organization', name: clientName },
				publisher: { '@type': 'Organization', name: clientName },
				mainEntityOfPage: canonicalURL.toString(),
		  }
		: null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
{customFavicon ? (
	<link rel="icon" href={customFavicon} />
) : (
	<>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
	</>
)}
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={clientName} href={new URL('rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />

<style is:inline define:vars={{ themePrimary }}>
	:root { --theme-primary: var(--themePrimary); }
</style>

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={clientName} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />

{articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />}
