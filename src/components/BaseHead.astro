---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { hexToRgbTuple, loadSettings } from '../lib/settings';

interface Props {
	title: string;
	description: string;
	ogType?: 'website' | 'article';
	publishedAt?: Date | null;
}

const settings = await loadSettings();
const clientName = settings.clientName;
const customFavicon = settings.clientFaviconUrl || null;

// Use html[data-theme="..."] (specificity 0,1,1) instead of :root / [data-theme] (0,1,0)
// so these win regardless of where Astro injects the bundled global.css <link>.
// Pre-paint script below sets dataset.theme before first paint, so one of the two always matches.
const themeCss = `
html[data-theme="light"] {
  --theme-primary: ${settings.themePrimaryColor};
  --bg-body: ${settings.colorBgLight};
  --bg-header: ${settings.colorHeaderBgLight};
  --black: ${hexToRgbTuple(settings.colorHeadingLight)};
  --gray-dark: ${hexToRgbTuple(settings.colorTextLight)};
  --gray: ${hexToRgbTuple(settings.colorMutedLight)};
  --gray-light: ${hexToRgbTuple(settings.colorBorderLight)};
}
html[data-theme="dark"] {
  --theme-primary: ${settings.themePrimaryColor};
  --bg-body: ${settings.colorBgDark};
  --bg-header: ${settings.colorHeaderBgDark};
  --black: ${hexToRgbTuple(settings.colorHeadingDark)};
  --gray-dark: ${hexToRgbTuple(settings.colorTextDark)};
  --gray: ${hexToRgbTuple(settings.colorMutedDark)};
  --gray-light: ${hexToRgbTuple(settings.colorBorderDark)};
}
`;

const { title, description, ogType = 'website', publishedAt } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleJsonLd =
	ogType === 'article'
		? {
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: title,
				description,
				datePublished: publishedAt ? publishedAt.toISOString() : undefined,
				author: { '@type': 'Organization', name: clientName },
				publisher: { '@type': 'Organization', name: clientName },
				mainEntityOfPage: canonicalURL.toString(),
		  }
		: null;
---

<!-- Runs before first paint to set theme without flash -->
<script is:inline>
  (function () {
    var saved = localStorage.getItem('edgepress-theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.dataset.theme = saved || (prefersDark ? 'dark' : 'light');
  })();
</script>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
{customFavicon ? (
	<link rel="icon" href={customFavicon} />
) : (
	<>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
	</>
)}
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={clientName} href={new URL('rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />

<style is:inline set:html={themeCss}></style>

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={clientName} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />

{articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />}
