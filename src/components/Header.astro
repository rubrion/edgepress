---
import { env } from 'cloudflare:workers';
import HeaderLink from './HeaderLink.astro';

const clientName = (env.CLIENT_NAME as string | undefined) ?? 'EdgePress';
const logoUrl = (env.CLIENT_LOGO_URL as string | undefined) || null;
---

<header>
	<nav>
		<h2>
			<a href="/">
				{logoUrl ? <img src={logoUrl} alt={clientName} class="logo" /> : clientName}
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 { margin: 0; font-size: 1em; }
	h2 a, h2 a.active { text-decoration: none; }
	.logo { height: 1.8em; width: auto; vertical-align: middle; display: inline-block; }
	nav { display: flex; align-items: center; justify-content: space-between; }
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
</style>
