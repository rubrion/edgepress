---
import { getLang, useTranslations } from '../i18n';
import { loadSettings } from '../lib/settings';
import HeaderLink from './HeaderLink.astro';

const settings = await loadSettings();
const clientName = settings.clientName;
const logoUrl = settings.clientLogoUrl || null;

const lang = getLang(Astro.request);
const t = useTranslations(lang);
const nextLang = lang === 'en' ? 'pt-BR' : 'en';
const langLabel = lang === 'en' ? 'PT' : 'EN';
---

<header>
	<nav>
		<h2>
			<a href="/">
				{logoUrl ? <img src={logoUrl} alt={clientName} class="logo" /> : clientName}
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">{t('nav.home')}</HeaderLink>
			<HeaderLink href="/blog">{t('nav.blog')}</HeaderLink>
			<HeaderLink href="/about">{t('nav.about')}</HeaderLink>
		</div>
		<div class="controls">
			<button id="theme-toggle" class="ctrl-btn" aria-label={t('nav.toggleDark')} title={t('nav.toggleDark')}>
				<span class="icon-sun">☀</span>
				<span class="icon-moon">☽</span>
			</button>
			<button
				id="lang-toggle"
				class="ctrl-btn lang-btn"
				aria-label={`Switch to ${nextLang}`}
				data-next-lang={nextLang}
			>{langLabel}</button>
		</div>
	</nav>
</header>

<script define:vars={{ toDark: t('nav.toDark'), toLight: t('nav.toLight') }}>
  // Dark mode toggle
  const themeBtn = document.getElementById('theme-toggle');
  function syncTheme() {
    const dark = document.documentElement.dataset.theme === 'dark';
    themeBtn.setAttribute('aria-label', dark ? toLight : toDark);
  }
  themeBtn.addEventListener('click', () => {
    const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    localStorage.setItem('edgepress-theme', next);
    syncTheme();
  });
  syncTheme();

  // Language toggle
  const langBtn = document.getElementById('lang-toggle');
  langBtn.addEventListener('click', () => {
    const next = langBtn.dataset.nextLang;
    document.cookie = `lang=${next}; path=/; max-age=31536000; SameSite=Lax`;
    window.location.reload();
  });
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg-header, #fff);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: background-color 0.2s;
	}
	h2 { margin: 0; font-size: 1em; }
	h2 a, h2 a.active { text-decoration: none; }
	.logo { height: 1.8em; width: auto; vertical-align: middle; display: inline-block; }
	nav { display: flex; align-items: center; justify-content: space-between; }
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

	.controls { display: flex; align-items: center; gap: 0.4rem; }

	.ctrl-btn {
		background: transparent;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		padding: 0.3em 0.55em;
		font-size: 1rem;
		line-height: 1;
		color: rgb(var(--black));
		display: flex;
		align-items: center;
		transition: color 0.2s;
	}
	.ctrl-btn:hover { color: var(--accent); }

	.lang-btn { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.04em; padding: 0.35em 0.6em; }

	/* Show sun in dark mode, moon in light mode */
	:global([data-theme="dark"]) .icon-sun { display: inline; }
	:global([data-theme="dark"]) .icon-moon { display: none; }
	:global([data-theme="light"]) .icon-sun { display: none; }
	:global([data-theme="light"]) .icon-moon { display: inline; }
	/* Fallback before script runs */
	.icon-sun { display: none; }
	.icon-moon { display: inline; }
</style>
