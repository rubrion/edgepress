---
import { loadSettings } from '../lib/settings';

interface Props {
  current?: 'posts' | 'subscribers' | 'settings';
}

const { current } = Astro.props;

const settings = await loadSettings();
const themeColor = settings.themePrimaryColor;
const clientName = settings.clientName;

const links: { key: NonNullable<Props['current']>; href: string; label: string }[] = [
  { key: 'posts', href: '/admin', label: 'Posts' },
  { key: 'subscribers', href: '/admin/subscribers', label: 'Subscribers' },
  { key: 'settings', href: '/admin/settings', label: 'Settings' },
];
---

<nav class="admin-appbar" style={`--theme: ${themeColor}`}>
  <div class="brand">{clientName}</div>
  <div class="links">
    {links.map((l) => (
      <a href={l.href} class:list={['nav-link', current === l.key && 'active']}>{l.label}</a>
    ))}
  </div>
  <a href="/api/admin/logout" id="admin-appbar-logout" class="signout">Sign out</a>
</nav>

<script>
  const logout = document.getElementById('admin-appbar-logout');
  logout?.addEventListener('click', async (e) => {
    e.preventDefault();
    await fetch('/api/admin/logout', { method: 'POST', credentials: 'same-origin' });
    window.location.href = '/admin/login';
  });
</script>

<style>
  .admin-appbar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.65rem 1.25rem;
    background: #fff;
    border-bottom: 1px solid #e5e5e8;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
    font-size: 0.9rem;
  }
  .brand {
    font-weight: 600;
    color: #1a1a1a;
    margin-right: 0.5rem;
  }
  .links {
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }
  .nav-link {
    color: #555;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    font-size: 0.85rem;
    transition: background 0.15s, color 0.15s;
  }
  .nav-link:hover { color: var(--theme); background: #f5f5f7; }
  .nav-link.active { color: var(--theme); background: #f5f5f7; font-weight: 500; }
  .signout {
    color: #555;
    text-decoration: none;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .signout:hover { color: var(--theme); }
</style>
