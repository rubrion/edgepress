---
import { type Lang, getLang } from '../i18n';

interface Props {
  date: Date;
  lang?: Lang;
}

const { date, lang: langProp } = Astro.props;
const lang = langProp ?? getLang(Astro.request);
const locale = lang === 'pt-BR' ? 'pt-BR' : 'en-US';
---

<time datetime={date.toISOString()}>
	{date.toLocaleDateString(locale, { year: 'numeric', month: 'short', day: 'numeric' })}
</time>
