---
import { env } from 'cloudflare:workers';
import { getLang, useTranslations } from '../i18n';
import SubscribeForm from './SubscribeForm.astro';

const clientName = (env.CLIENT_NAME as string | undefined) ?? 'EdgePress';
const today = new Date();

const lang = getLang(Astro.request);
const t = useTranslations(lang);
---

<SubscribeForm lang={lang} />

<footer>
	&copy; {today.getFullYear()} {clientName}. {t('footer.rights')}
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background-color: var(--bg-body);
		background-image: linear-gradient(var(--gray-gradient));
		background-repeat: no-repeat;
		color: rgb(var(--gray));
		text-align: center;
		transition: background-color 0.2s;
	}
</style>
