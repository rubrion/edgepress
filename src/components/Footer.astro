---
import { env } from 'cloudflare:workers';
import SubscribeForm from './SubscribeForm.astro';

const clientName = (env.CLIENT_NAME as string | undefined) ?? 'EdgePress';
const today = new Date();
---

<SubscribeForm />

<footer>
	&copy; {today.getFullYear()} {clientName}. All rights reserved.
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
</style>
