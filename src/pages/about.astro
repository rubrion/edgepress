---
import Layout from '../layouts/BlogPost.astro';
import { getLang, useTranslations } from '../i18n';
import { loadSettings } from '../lib/settings';

const lang = getLang(Astro.request);
const t = useTranslations(lang);

const settings = await loadSettings();
const clientName = settings.clientName;
---

<Layout title={`About — ${clientName}`} description={`About ${clientName}.`} lang={lang}>
	<p set:html={t('about.body', { name: clientName })} />
</Layout>
