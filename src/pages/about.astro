---
import Layout from '../layouts/BlogPost.astro';
import { getLang, useTranslations } from '../i18n';
import { loadSettings } from '../lib/settings';

const lang = getLang(Astro.request);
const t = useTranslations(lang);

const settings = await loadSettings();
const clientName = settings.clientName;

const rawBody = lang === 'pt-BR' ? settings.aboutBodyPt : settings.aboutBodyEn;
const body = rawBody.replaceAll('{name}', clientName);

const title = t('about.title');
---

<Layout title={`${title} — ${clientName}`} description={`${title} ${clientName}.`} lang={lang}>
	<div set:html={body} />
</Layout>
