---
import { env } from 'cloudflare:workers';
import Layout from '../layouts/BlogPost.astro';
import { getLang, useTranslations } from '../i18n';

const lang = getLang(Astro.request);
const t = useTranslations(lang);

const clientName = (env.CLIENT_NAME as string | undefined) ?? 'EdgePress';
---

<Layout title={`About — ${clientName}`} description={`About ${clientName}.`} lang={lang}>
	<p set:html={t('about.body', { name: clientName })} />
</Layout>
