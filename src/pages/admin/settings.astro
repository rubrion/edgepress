---
import { env } from 'cloudflare:workers';
import { loadSettings } from '../../lib/settings';
import AdminAppbar from '../../components/AdminAppbar.astro';

const settings = await loadSettings();
const saved = Astro.url.searchParams.get('saved') === '1';
const error = Astro.url.searchParams.get('error');
const themeColor = settings.themePrimaryColor;

const provider = (env as unknown as { EMAIL_PROVIDER?: string }).EMAIL_PROVIDER === 'GMAIL' ? 'GMAIL' : 'RESEND';
const clientDomain = (env as unknown as { CLIENT_DOMAIN?: string }).CLIENT_DOMAIN ?? '';
const fromDomain = (env as unknown as { EMAIL_FROM_DOMAIN?: string }).EMAIL_FROM_DOMAIN || clientDomain;
const gmailUser = (env as unknown as { GMAIL_USER?: string }).GMAIL_USER ?? '';

const lightColors = [
  { key: 'colorBgLight', label: 'Body background' },
  { key: 'colorHeaderBgLight', label: 'Header background' },
  { key: 'colorHeadingLight', label: 'Heading text' },
  { key: 'colorTextLight', label: 'Body text' },
  { key: 'colorMutedLight', label: 'Muted / secondary text' },
  { key: 'colorBorderLight', label: 'Borders & code background' },
] as const;

const darkColors = [
  { key: 'colorBgDark', label: 'Body background' },
  { key: 'colorHeaderBgDark', label: 'Header background' },
  { key: 'colorHeadingDark', label: 'Heading text' },
  { key: 'colorTextDark', label: 'Body text' },
  { key: 'colorMutedDark', label: 'Muted / secondary text' },
  { key: 'colorBorderDark', label: 'Borders & code background' },
] as const;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Settings — {settings.clientName}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <style is:global>
    body { font-family: -apple-system, Segoe UI, sans-serif; background: #f5f5f7; margin: 0; min-height: 100vh; color: #1a1a1a; }
    .wrap { max-width: 720px; margin: 2rem auto; padding: 0 1rem; }
    .card { background: #fff; padding: 2rem; border-radius: 12px; border-top: 4px solid var(--theme); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
    h1 { margin: 0 0 0.25rem; font-size: 1.4rem; }
    h2 { margin: 2rem 0 0.75rem; font-size: 1rem; color: #444; border-bottom: 1px solid #eee; padding-bottom: 0.5rem; }
    h2:first-of-type { margin-top: 1.5rem; }
    .sub { margin: 0 0 1.5rem; color: #777; font-size: 0.9rem; }
    .field { margin-bottom: 1.1rem; }
    label { display: block; font-size: 0.85rem; color: #555; margin-bottom: 0.4rem; font-weight: 500; }
    .hint { font-size: 0.75rem; color: #888; margin-top: 0.25rem; }
    input[type="text"], input[type="url"], input[type="email"], textarea {
      width: 100%; padding: 0.55rem 0.75rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; box-sizing: border-box; font-family: inherit;
    }
    input:disabled { background: #f5f5f7; color: #888; cursor: not-allowed; }
    textarea { min-height: 70px; resize: vertical; }
    input[type="color"] { width: 48px; height: 36px; padding: 0; border: 1px solid #ddd; border-radius: 6px; cursor: pointer; vertical-align: middle; }
    .color-row { display: flex; align-items: center; gap: 0.6rem; }
    .color-row input[type="text"] { flex: 1; max-width: 140px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem; }
    .color-grid { display: grid; gap: 0.85rem; }
    .color-grid .field { margin: 0; }
    .email-row { display: flex; align-items: stretch; }
    .email-row input[type="text"] { border-top-right-radius: 0; border-bottom-right-radius: 0; border-right: none; }
    .email-row .domain {
      display: flex; align-items: center; padding: 0 0.75rem;
      background: #f5f5f7; border: 1px solid #ddd; border-left: none;
      border-top-right-radius: 6px; border-bottom-right-radius: 6px;
      color: #555; font-size: 0.9rem; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    }
    .actions { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1.5rem; }
    button[type="submit"] { padding: 0.6rem 1.2rem; background: var(--theme); color: #fff; border: none; border-radius: 6px; font-size: 0.95rem; cursor: pointer; font-weight: 500; }
    .alert { padding: 0.6rem 0.8rem; border-radius: 6px; font-size: 0.85rem; margin-bottom: 1rem; }
    .alert.ok { background: #e7f5ec; color: #2c7a3e; }
    .alert.err { background: #fdecec; color: #b3261e; }
  </style>
</head>
<body style={`--theme: ${themeColor}`}>
  <AdminAppbar current="settings" />
  <div class="wrap">
    <div class="card">
      <h1>Site settings</h1>
      <p class="sub">Brand visuals stored in the database. Empty a field to fall back to the seed value in <code>wrangler.jsonc</code>.</p>

      {saved && <div class="alert ok">Saved.</div>}
      {error && <div class="alert err">{error}</div>}

      <form method="POST" action="/api/admin/settings">
        <h2>Brand</h2>

        <div class="field">
          <label for="clientName">Brand name</label>
          <input type="text" id="clientName" name="clientName" value={settings.clientName} />
        </div>

        <div class="field">
          <label for="clientTagline">Tagline</label>
          <textarea id="clientTagline" name="clientTagline">{settings.clientTagline}</textarea>
        </div>

        <div class="field">
          <label for="clientLogoUrl">Logo URL</label>
          <input type="url" id="clientLogoUrl" name="clientLogoUrl" value={settings.clientLogoUrl} placeholder="https://..." />
          <div class="hint">Public URL of the brand logo. Leave empty to show the brand name as text.</div>
        </div>

        <div class="field">
          <label for="clientFaviconUrl">Favicon URL</label>
          <input type="url" id="clientFaviconUrl" name="clientFaviconUrl" value={settings.clientFaviconUrl} placeholder="https://..." />
        </div>

        <h2>About page</h2>

        <div class="field">
          <label for="aboutBodyEn">About body (English)</label>
          <textarea id="aboutBodyEn" name="aboutBodyEn" rows="4">{settings.aboutBodyEn}</textarea>
          <div class="hint">Use <code>{'{name}'}</code> as a placeholder for the brand name. HTML allowed. Leave empty to restore the default.</div>
        </div>

        <div class="field">
          <label for="aboutBodyPt">About body (Português)</label>
          <textarea id="aboutBodyPt" name="aboutBodyPt" rows="4">{settings.aboutBodyPt}</textarea>
          <div class="hint">Use <code>{'{name}'}</code> como espaço reservado para o nome da marca. HTML permitido.</div>
        </div>

        <h2>Email</h2>

        {provider === 'GMAIL' ? (
          <div class="field">
            <label>Email "from" address</label>
            <input type="email" value={gmailUser} disabled />
            <div class="hint">
              Provider is <strong>GMAIL</strong>. Gmail forces the From address to <code>GMAIL_USER</code>;
              edit that secret in <code>wrangler.jsonc</code> / Cloudflare to change it.
            </div>
          </div>
        ) : (
          <div class="field">
            <label for="emailFromLocal">Email "from" address</label>
            <div class="email-row">
              <input
                type="text"
                id="emailFromLocal"
                name="emailFromLocal"
                value={settings.emailFromLocal}
                placeholder="noreply"
                pattern="^[A-Za-z0-9._%+\\-]+$"
                autocomplete="off"
              />
              <span class="domain">@{fromDomain}</span>
            </div>
            <div class="hint">
              Provider is <strong>RESEND</strong>. Only the part before <code>@</code> is editable —
              the domain comes from <code>EMAIL_FROM_DOMAIN</code> in <code>wrangler.jsonc</code>
              (must be verified in Resend), independent of <code>CLIENT_DOMAIN</code>.
            </div>
          </div>
        )}

        <h2>Theme colors — primary</h2>

        <div class="field">
          <label for="themePrimaryColor">Primary / accent color</label>
          <div class="color-row">
            <input type="color" data-picker-for="themePrimaryColor" value={settings.themePrimaryColor} />
            <input type="text" id="themePrimaryColor" name="themePrimaryColor" value={settings.themePrimaryColor} pattern="^#[0-9a-fA-F]{3,8}$" />
          </div>
          <div class="hint">Buttons, links, focus rings, accents.</div>
        </div>

        <h2>Light mode</h2>
        <div class="color-grid">
          {lightColors.map(({ key, label }) => (
            <div class="field">
              <label for={key}>{label}</label>
              <div class="color-row">
                <input type="color" data-picker-for={key} value={settings[key]} />
                <input type="text" id={key} name={key} value={settings[key]} pattern="^#[0-9a-fA-F]{3,8}$" />
              </div>
            </div>
          ))}
        </div>

        <h2>Dark mode</h2>
        <div class="color-grid">
          {darkColors.map(({ key, label }) => (
            <div class="field">
              <label for={key}>{label}</label>
              <div class="color-row">
                <input type="color" data-picker-for={key} value={settings[key]} />
                <input type="text" id={key} name={key} value={settings[key]} pattern="^#[0-9a-fA-F]{3,8}$" />
              </div>
            </div>
          ))}
        </div>

        <div class="actions">
          <button type="submit">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Two-way bind every color picker with its sibling hex text input.
    document.querySelectorAll<HTMLInputElement>('input[type="color"][data-picker-for]').forEach((picker) => {
      const targetId = picker.dataset.pickerFor;
      if (!targetId) return;
      const text = document.getElementById(targetId) as HTMLInputElement | null;
      if (!text) return;
      picker.addEventListener('input', () => { text.value = picker.value; });
      text.addEventListener('input', () => {
        if (/^#[0-9a-fA-F]{6}$/.test(text.value)) picker.value = text.value;
      });
    });
  </script>
</body>
</html>
