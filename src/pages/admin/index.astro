---
import { env } from 'cloudflare:workers';
import AdminEditor from '../../components/AdminEditor.tsx';
import AdminAppbar from '../../components/AdminAppbar.astro';
import { getDbInstance, aiUsage, campaigns, posts } from '../../db';
import { desc, eq, inArray } from 'drizzle-orm';
import { loadSettings } from '../../lib/settings';

const db = getDbInstance();
const recent = await db
  .select({
    id: posts.id,
    title: posts.title,
    slug: posts.slug,
    contentMd: posts.contentMd,
    isPublished: posts.isPublished,
    publishedAt: posts.publishedAt,
  })
  .from(posts)
  .orderBy(desc(posts.publishedAt))
  .limit(20);

// Aggregate the latest successful campaign per post (single round-trip).
const lastSentByPost = new Map<string, Date>();
if (recent.length > 0) {
  const rows = await db
    .select({
      postId: campaigns.postId,
      sentAt: campaigns.sentAt,
      status: campaigns.status,
    })
    .from(campaigns)
    .where(inArray(campaigns.postId, recent.map((p) => p.id)));
  for (const c of rows) {
    if (c.status !== 'sent' && c.status !== 'partial') continue;
    const cur = lastSentByPost.get(c.postId);
    if (!cur || c.sentAt.getTime() > cur.getTime()) {
      lastSentByPost.set(c.postId, c.sentAt);
    }
  }
}

const settings = await loadSettings();
const themeColor = settings.themePrimaryColor;
const clientName = settings.clientName;

const aiLimitRaw = (env as unknown as { AI_REVIEW_DAILY_TOKEN_LIMIT?: string }).AI_REVIEW_DAILY_TOKEN_LIMIT;
const aiLimit = Number.parseInt(aiLimitRaw ?? '', 10);
let aiUsedToday = 0;
if (Number.isFinite(aiLimit) && aiLimit > 0) {
  const today = new Date().toISOString().slice(0, 10);
  try {
    const row = await db.select().from(aiUsage).where(eq(aiUsage.day, today)).limit(1);
    aiUsedToday = row[0]?.tokensUsed ?? 0;
  } catch {
    aiUsedToday = 0;
  }
}
const initialAiUsage = Number.isFinite(aiLimit) && aiLimit > 0
  ? { used: aiUsedToday, limit: aiLimit }
  : null;

const recentSerialized = recent.map((p) => ({
  id: p.id,
  title: p.title,
  slug: p.slug,
  contentMd: p.contentMd,
  isPublished: p.isPublished,
  publishedAt: p.publishedAt ? p.publishedAt.toISOString() : null,
  lastSentAt: lastSentByPost.get(p.id)?.toISOString() ?? null,
}));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin — {clientName}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <style is:global>
    html, body { height: 100%; }
    body { font-family: -apple-system, Segoe UI, sans-serif; margin: 0; background: #f5f5f7; color: #1a1a1a; display: flex; flex-direction: column; }
  </style>
</head>
<body style={`--theme: ${themeColor}`}>
  <AdminAppbar current="posts" />
  <div style="flex: 1; min-height: 0;">
    <AdminEditor client:only="react" recent={recentSerialized} initialAiUsage={initialAiUsage} />
  </div>
</body>
</html>
