---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getLang, useTranslations } from '../i18n';
import { loadSettings } from '../lib/settings';
import { getDbInstance, posts } from '../db';
import { desc, eq } from 'drizzle-orm';

const lang = getLang(Astro.request);
const t = useTranslations(lang);

const settings = await loadSettings();
const clientName = settings.clientName;
const description = `Latest from ${clientName}.`;
const tagline = settings.clientTagline || 'Notes, essays, and announcements — straight to your inbox.';

const db = getDbInstance();
const recent = await db
	.select({ slug: posts.slug, title: posts.title, publishedAt: posts.publishedAt })
	.from(posts)
	.where(eq(posts.isPublished, true))
	.orderBy(desc(posts.publishedAt))
	.limit(5);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={clientName} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{clientName}</h1>
				<p>{tagline}</p>
			</section>
			{recent.length > 0 && (
				<section>
					<h2>{t('index.latestPosts')}</h2>
					<ul class="post-list">
						{recent.map((p) => (
							<li>
								<a href={`/blog/${p.slug}`}>
									<span class="title">{p.title}</span>
									{p.publishedAt && (
										<span class="date"><FormattedDate date={p.publishedAt} lang={lang} /></span>
									)}
								</a>
							</li>
						))}
					</ul>
					<p><a href="/blog">{t('index.allPosts')}</a></p>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero { text-align: center; padding: 3em 0 1em; }
	.hero h1 { font-size: 3em; margin-bottom: 0.2em; }
	.hero p { color: rgb(var(--gray)); font-size: 1.1em; }
	.post-list { list-style: none; padding: 0; margin: 0; }
	.post-list li { border-bottom: 1px solid rgb(var(--gray-light)); }
	.post-list li:last-child { border-bottom: none; }
	.post-list a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		padding: 0.9em 0;
		text-decoration: none;
		color: rgb(var(--gray-dark));
	}
	.post-list a:hover .title { color: var(--accent); }
	.post-list .title { font-weight: 600; }
	.post-list .date { color: rgb(var(--gray)); font-size: 0.9em; flex-shrink: 0; }
</style>
